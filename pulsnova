       // --- VISOR DE ZOOM + GALERÍA MEJORADO (SIN TITILEO) ---
        function ImageViewer({ images, currentIndex, onIndexChange, onClose }) {
            const [transform, setTransform] = useState({ x: 0, y: 0, scale: 1 });
            const [isInteracting, setIsInteracting] = useState(false); // <--- NUEVO: Para apagar animación al tocar
            const containerRef = useRef(null);
            const gesture = useRef({ startDist: 0, startScale: 1, startX: 0, startY: 0, startTransX: 0, startTransY: 0, lastTap: 0 });

            // Resetear zoom al cambiar de imagen
            useEffect(() => { setTransform({ x: 0, y: 0, scale: 1 }); }, [currentIndex]);

            const handleNext = (e) => { if(e) e.stopPropagation(); if (currentIndex < images.length - 1) onIndexChange(currentIndex + 1); else onIndexChange(0); };
            const handlePrev = (e) => { if(e) e.stopPropagation(); if (currentIndex > 0) onIndexChange(currentIndex - 1); else onIndexChange(images.length - 1); };

            useEffect(() => {
                const el = containerRef.current;
                if (!el) return;
                const getDist = (e) => Math.hypot(e.touches[0].pageX - e.touches[1].pageX, e.touches[0].pageY - e.touches[1].pageY);

                const handleTouchStart = (e) => {
                    setIsInteracting(true); // Desactivamos transición para movimiento instantáneo
                    
                    if (e.touches.length === 2) {
                        gesture.current.startDist = getDist(e);
                        gesture.current.startScale = transform.scale;
                    } else if (e.touches.length === 1) {
                        gesture.current.startX = e.touches[0].pageX;
                        gesture.current.startY = e.touches[0].pageY;
                        gesture.current.startTransX = transform.x;
                        gesture.current.startTransY = transform.y;
                        
                        // Doble toque
                        const now = Date.now();
                        if (now - gesture.current.lastTap < 300) {
                            setIsInteracting(false); // En doble tap sí queremos animación
                            const newScale = transform.scale > 1 ? 1 : 3;
                            setTransform({ x: 0, y: 0, scale: newScale });
                        }
                        gesture.current.lastTap = now;
                    }
                };


                const handleTouchMove = (e) => {
                    e.preventDefault(); // Prevenir scroll del navegador
                    
                    if (e.touches.length === 2) {
                        const scaleFactor = getDist(e) / gesture.current.startDist;
                        setTransform(prev => ({ ...prev, scale: Math.max(1, Math.min(gesture.current.startScale * scaleFactor, 5)) }));
                    } else if (e.touches.length === 1) {
                        const dx = e.touches[0].pageX - gesture.current.startX;
                        const dy = e.touches[0].pageY - gesture.current.startY;
                        
                        if (transform.scale > 1) {
                            // Mover solo si hay zoom
                            setTransform(prev => ({ ...prev, x: gesture.current.startTransX + dx, y: gesture.current.startTransY + dy }));
                        }
                    }
                };

                const handleTouchEnd = (e) => {
                    setIsInteracting(false); // Reactivamos transición suave al soltar
                    
                    if (transform.scale === 1 && e.changedTouches.length === 1) {
                        // Lógica de Swipe
                        const dx = e.changedTouches[0].pageX - gesture.current.startX;
                        if (Math.abs(dx) > 50) { 
                            if (dx > 0) handlePrev(); 
                            else handleNext();        
                        }
                    }
                };
                
                el.addEventListener('touchstart', handleTouchStart, { passive: false });
                el.addEventListener('touchmove', handleTouchMove, { passive: false });
                el.addEventListener('touchend', handleTouchEnd);
                return () => {
                    el.removeEventListener('touchstart', handleTouchStart);
                    el.removeEventListener('touchmove', handleTouchMove);
                    el.removeEventListener('touchend', handleTouchEnd);
                };
            }, [transform, currentIndex]);
            
