        // --- COMPONENTE: RECORTADOR DE IMAGEN (MEJORADO PARA BANNERS) ---
        function ImageCropper({ imageSrc, onCrop, onCancel, aspect = 1, finalWidth = 800 }) {
            const imageRef = useRef(null);
            const cropperRef = useRef(null);

            useEffect(() => {
                if (imageRef.current) {
                    cropperRef.current = new Cropper(imageRef.current, {
                        aspectRatio: aspect, // Ahora es dinámico (1 para productos, 16/9 para banners)
                        viewMode: 1,
                        dragMode: 'move',
                        autoCropArea: 1,
                        background: false,
                        responsive: true,
                    });
                }
                return () => {
                    if (cropperRef.current) cropperRef.current.destroy();
                };
            }, [aspect]);

            const handleCrop = () => {
                if (cropperRef.current) {
                    // Calculamos altura basada en el aspecto para mantener calidad
                    const width = finalWidth;
                    // Si no hay aspecto definido, usamos el natural
                    
                    const canvas = cropperRef.current.getCroppedCanvas({
                        minWidth: width,
                        maxWidth: 2048, // Permitimos hasta 2K (Suficiente y seguro)
                        imageSmoothingEnabled: true,
                        imageSmoothingQuality: 'high',
                    });
                    
                    // CALIDAD 0.95 (Casi perfecta, sin artefactos)
                    // Nota: 1.0 suele pesar demasiado y fallar al guardar.
                    onCrop(canvas.toDataURL('image/jpeg', 0.95)); 
                }
            };

            return (
				
																			
																			<div className="fixed inset-0 z-[80] bg-black flex flex-col animate-fade-in">
																				<div className="flex justify-between items-center p-4 bg-black z-10 border-b border-gray-800">
