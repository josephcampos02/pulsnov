  <script type="text/babel"> const { useState, useEffect, useCallback, useMemo, useRef } = React;
        const { createRoot } = ReactDOM;

        const EMAIL_CONFIG = { SERVICE_ID: "service_aqjhcas", TEMPLATE_ID: "template_g91aq2p", PUBLIC_KEY: "jm9nKZPtBQ6tCWLUa" };
        try { emailjs.init(EMAIL_CONFIG.PUBLIC_KEY); } catch(e) { console.log("EmailJS configurado"); }

        // --- CLOUD DB MANAGER (MODIFICADO PARA FILTRAR PEDIDOS) ---
        const CloudDB = {
            logVisit: async () => {
                if (sessionStorage.getItem('pulsnova_visit_counted')) return; 
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                if (localStorage.getItem('pulsnova_admin_auth') === 'true') {
                    console.log("🚫 Visita de Admin ignorada (Modo Pruebas).");
                    sessionStorage.setItem('pulsnova_visit_counted', 'true'); 
                    return; 
                }
                let visitorName = "Anónimo / Nuevo";
                try {
                    const savedUser = localStorage.getItem('pulsnova_user_data');
                    if (savedUser) { const u = JSON.parse(savedUser); visitorName = `${u.nombre} ${u.apellido || ''}`.trim(); }
                } catch (e) {}
                try {
                    const { addDoc, collection, serverTimestamp } = window.FIREBASE_HELPERS;
                    await addDoc(collection(window.FIREBASE_DB, "visitas_log"), { date: serverTimestamp(), device: navigator.platform || "N/A", visitorName: visitorName });
                    sessionStorage.setItem('pulsnova_visit_counted', 'true');
                } catch (e) { console.error("Error log visita", e); }
            },
            
            // --- CAMBIO 1: GUARDAR EMAIL EN EL PEDIDO ---
            saveOrder: async (checkoutData, cart, total, promoDiscount, shippingInfo) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return false;
                try {
                    const { addDoc, collection, serverTimestamp } = window.FIREBASE_HELPERS;
                    const isAdmin = localStorage.getItem('pulsnova_admin_auth') === 'true';
                    
                    // Intentamos obtener el email del usuario logueado para asociarlo al pedido
                    let userEmail = null;
                    try {
                        const u = JSON.parse(localStorage.getItem('pulsnova_user_data'));
                        if(u && u.email) userEmail = u.email;
                    } catch(e){}

                    await addDoc(collection(window.FIREBASE_DB, "ventas"), {
                        client: checkoutData.nombre || "Cliente",
                        phone: checkoutData.telefono || "",
                        address: checkoutData.direccion || "",
                        province: checkoutData.provincia || "",
                        userEmail: typeof userEmail !== 'undefined' ? userEmail : "",
                        shippingMethod: (shippingInfo && shippingInfo.name) ? shippingInfo.name : "N/A",
                        
                        // Blindamos los items para que el precio siempre sea un número
                        items: cart.map(i => ({ 
                            name: i.nombre || "Producto", 
                            qty: Number(i.qty) || 1, 
                            price: Number(i.precio) || 0, 
                            size: i.talla || "Única" 
                        })),
                        
                        // Blindamos el total para que jamás llegue vacío a la base de datos
                        total: Number(total) || 0,
                        date: window.FIREBASE_HELPERS.serverTimestamp()
                    });
                    
                    if(isAdmin) alert("🛠️ Pedido guardado como PRUEBA (No afectará estadísticas).");
                    return true;
                } catch (e) { console.error("Error guardando venta:", e); return false; }
            },
            
            saveSubscriber: async (data, memberId) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return false;
                try {
                    const { addDoc, collection, serverTimestamp } = window.FIREBASE_HELPERS;
                    // CAMBIO: De "registros_clientes" a "clientes"
                    await addDoc(collection(window.FIREBASE_DB, "clientes"), {
                        nombre: data.nombre || "", 
                        apellido: data.apellido || "", 
                        email: data.email || "", 
                        fecha_nacimiento: data.dob || "", 
                        member_id: memberId, 
                        fecha_registro: serverTimestamp()
                    });
                    return true;
                } catch (e) { 
                    console.error("Error guardando registro:", e); 
                    return false; 
                }
            },
            
            listenToStats: (callback) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return () => {};
                const { query, collection, orderBy, onSnapshot } = window.FIREBASE_HELPERS;
                try {
                    const qSales = query(collection(window.FIREBASE_DB, "ventas"), orderBy("date", "desc"));
                    const qVisits = query(collection(window.FIREBASE_DB, "visitas_log"));
                    const unsubSales = onSnapshot(qSales, (snapSales) => {
                        const now = new Date();
                        const currentMonth = now.getMonth(); 
                        const currentYear = now.getFullYear();
                        let totalSalesMonth = 0; 
                        let ordersCountMonth = 0;
                        snapSales.forEach(d => {
                            const data = d.data();
                            if (data.isTest === true || data.status === 'test') return;
                            const saleDate = data.date ? new Date(data.date.seconds * 1000) : new Date();
                            if (saleDate.getMonth() === currentMonth && saleDate.getFullYear() === currentYear) {
                                totalSalesMonth += (Number(data.total) || 0);
                                ordersCountMonth++;
                            }
                        });
                        onSnapshot(qVisits, (snapVisits) => { 
                            let visitsCountMonth = 0;
                            snapVisits.forEach(d => {
                                const data = d.data();
                                const visitDate = data.date ? new Date(data.date.seconds * 1000) : new Date();
                                if (visitDate.getMonth() === currentMonth && visitDate.getFullYear() === currentYear) { visitsCountMonth++; }
                            });
                            callback({ salesCount: visitsCountMonth, totalSales: totalSalesMonth, ordersCount: ordersCountMonth }); 
                        });
                    });
                    return unsubSales;
                } catch (e) { return () => {}; }
            },
            
            downloadExcel: async () => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) { alert("Conectando con la base de datos... espere."); return; }
                if (!window.XLSX) { alert("Cargando sistema Excel... intente de nuevo."); return; }
                const { getDocs, collection, query, orderBy } = window.FIREBASE_HELPERS;
                try {
                    const wb = window.XLSX.utils.book_new();
                    const qVentas = query(collection(window.FIREBASE_DB, "ventas"), orderBy("date", "desc"));
                    const snapVentas = await getDocs(qVentas);
                    if (!snapVentas.empty) {
                        const salesByMonth = {}; 
                        snapVentas.forEach(doc => {
                            const d = doc.data(); 
                            if (d.isTest === true || d.status === 'test') return;
                            const dateObj = d.date ? new Date(d.date.seconds * 1000) : new Date(); const monthKey = dateObj.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' }).toUpperCase();
                            if (!salesByMonth[monthKey]) salesByMonth[monthKey] = [];
                            const itemsStr = d.items ? d.items.map(i => `${i.qty}x ${i.name} (${i.size})`).join(", ") : "";
                            salesByMonth[monthKey].push({ "Fecha": dateObj.toLocaleDateString('es-PA'), "Cliente": d.client, "Pulseras (Items)": itemsStr, "Provincia": d.province || "-", "Envío": d.shippingMethod || "-",  "Forma de Pago": d.paymentMethod || "-", "Total (Sin Envío)": Number(d.total) || 0 });
                        });
                        let finalData = [];
                        for (const [month, rows] of Object.entries(salesByMonth)) {
                            finalData.push({ "Fecha": `--- ${month} ---` }); rows.forEach(r => finalData.push(r));
                            const monthTotal = rows.reduce((sum, r) => sum + r["Total (Sin Envío)"], 0);
                            finalData.push({ "Fecha": "", "Envío": "TOTAL MES (Prod):", "Total (Sin Envío)": monthTotal }); finalData.push({}); 
                        }
                        const wsVentas = window.XLSX.utils.json_to_sheet(finalData); wsVentas['!cols'] = [{ wch: 12 }, { wch: 20 }, { wch: 40 }, { wch: 15 }, { wch: 20 }, { wch: 20 }, { wch: 15 }]; window.XLSX.utils.book_append_sheet(wb, wsVentas, "Reporte Ventas");
                    } else { window.XLSX.utils.book_append_sheet(wb, window.XLSX.utils.json_to_sheet([{Info: "Sin ventas"}]), "Reporte Ventas"); }

                    const qVisitas = query(collection(window.FIREBASE_DB, "visitas_log"), orderBy("date", "desc"));
                    const snapVisitas = await getDocs(qVisitas);
                    if (!snapVisitas.empty) {
                        const visitasData = []; snapVisitas.forEach(doc => { const d = doc.data(); const dateObj = d.date ? new Date(d.date.seconds * 1000) : new Date(); visitasData.push({ "Fecha": dateObj.toLocaleDateString('es-PA'), "Hora": dateObj.toLocaleTimeString('es-PA'), "Visitante": d.visitorName || "Anónimo", "Dispositivo": d.device || "-" }); });
                        const wsVisitas = window.XLSX.utils.json_to_sheet(visitasData); wsVisitas['!cols'] = [{ wch: 12 }, { wch: 12 }, { wch: 25 }, { wch: 20 }]; window.XLSX.utils.book_append_sheet(wb, wsVisitas, "Registro Visitas");
                    } else { window.XLSX.utils.book_append_sheet(wb, window.XLSX.utils.json_to_sheet([{Info: "Sin visitas registradas"}]), "Registro Visitas"); }
                    window.XLSX.writeFile(wb, `PULSNOVA_Reporte_${new Date().toISOString().split('T')[0]}.xlsx`);
                } catch (e) { console.error(e); alert("Error generando reporte: " + e.message); }
            },
            // --- Reemplaza la función listenToProducts por esta (con ordenamiento) ---
            listenToProducts: (callback) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return () => {};
                const { collection, onSnapshot, query } = window.FIREBASE_HELPERS;
                // Nota: Obtenemos todos y ordenamos en el cliente para no perder los que no tengan índice
                const q = query(collection(window.FIREBASE_DB, "productos"));
                return onSnapshot(q, (snap) => {
                    const prods = [];
                    snap.forEach(doc => prods.push({ ...doc.data(), id: doc.id }));
                    
                    // LÓGICA DE ORDENAMIENTO
                    prods.sort((a, b) => {
                        const orderA = a.orderIndex !== undefined ? a.orderIndex : 9999;
                        const orderB = b.orderIndex !== undefined ? b.orderIndex : 9999;
                        return orderA - orderB;
                    });
                    
                    callback(prods);
                });
            },

            // --- AGREGA ESTA NUEVA FUNCIÓN dentro de CloudDB ---
            saveProduct: async (product) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                const { setDoc, doc } = window.FIREBASE_HELPERS;

                try {
                    // Aseguramos que el ID sea string para Firebase
                    const docRef = doc(window.FIREBASE_DB, "productos", String(product.id));
                    
                    // Guardamos el producto (si existe lo actualiza, si no, lo crea)
                    await setDoc(docRef, product, { merge: true });
                    
                    alert("✅ Producto guardado correctamente en la Nube.");
                } catch (e) {
                    console.error("Error guardando producto:", e);
                    alert("❌ Error al guardar: " + e.message);
                }
            },
            deleteProduct: async (id) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                const { deleteDoc, doc } = window.FIREBASE_HELPERS;
                await deleteDoc(doc(window.FIREBASE_DB, "productos", String(id)));
            },
            
            // --- CAMBIO 2: FILTRAR POR EMAIL SI ES NECESARIO ---
            listenToOrders: (callback, filterEmail = null) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return () => {};
                const { collection, query, orderBy, onSnapshot } = window.FIREBASE_HELPERS;
                const q = query(collection(window.FIREBASE_DB, "ventas"), orderBy("date", "desc"));
                
                return onSnapshot(q, (snap) => {
                    const orders = [];
                    snap.forEach(doc => {
                        const d = doc.data();
                        
                        // SI HAY UN EMAIL DE FILTRO Y NO COINCIDE, SALTAMOS ESTE PEDIDO
                        if (filterEmail && d.userEmail !== filterEmail) return;

                        const dateObj = d.date ? new Date(d.date.seconds * 1000) : new Date();
                        orders.push({ 
                            ...d, 
                            id: doc.id,
                            client: d.isTest ? `[PRUEBA] ${d.client}` : d.client,
                            fechaStr: dateObj.toLocaleDateString('es-PA') + ' ' + dateObj.toLocaleTimeString('es-PA')
                        });
                    });
                    callback(orders);
                });
            },
            
            deleteOrder: async (id) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                const { deleteDoc, doc } = window.FIREBASE_HELPERS;
                if(!confirm("⚠️ ¿Estás seguro de ELIMINAR este pedido permanentemente?\n\nEsta acción no se puede deshacer.")) return;
                try {
                    await deleteDoc(doc(window.FIREBASE_DB, "ventas", String(id)));
                } catch (e) { console.error("Error eliminando:", e); alert("❌ Error al eliminar el pedido."); }
            },
            listenToConfig: (callback) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return () => {};
                const { doc, onSnapshot } = window.FIREBASE_HELPERS;
                return onSnapshot(doc(window.FIREBASE_DB, "configuracion", "general"), (docSnap) => {
                    if (docSnap.exists()) { callback(docSnap.data()); }
                });
            },
            saveConfig: async (heroConfig, promosList, timerConfig) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                const { setDoc, doc } = window.FIREBASE_HELPERS;
                try {
                    await setDoc(doc(window.FIREBASE_DB, "configuracion", "general"), { 
                        hero: heroConfig, 
                        promos: promosList, 
                        timer: timerConfig, // <-- Se agrega el temporizador
                        updatedAt: new Date() 
                    }, { merge: true });
                    alert("✅ Cambios guardados en la Nube (visible para todos).");
                } catch (e) { console.error("Error guardando config:", e); alert("❌ Error al guardar en la nube."); }
            },

            // --- NUEVA FUNCIÓN PARA GUARDAR EL ORDEN ---
            saveProductsOrder: async (products) => {
                if (!window.FIREBASE_DB || !window.FIREBASE_HELPERS) return;
                const { setDoc, doc } = window.FIREBASE_HELPERS;
                
                // Confirmación para evitar clicks accidentales
                if(!confirm("¿Guardar este nuevo orden de productos?")) return;

                try {
                    // Actualizamos cada producto con su nuevo índice (0, 1, 2...)
                    const updates = products.map((p, index) => {
                        const docRef = doc(window.FIREBASE_DB, "productos", String(p.id));
                        // 'merge: true' es vital para no borrar el nombre o precio, solo actualizamos el orden
                        return setDoc(docRef, { orderIndex: index }, { merge: true });
                    });

                    await Promise.all(updates);
                    alert("✅ ¡Orden guardado correctamente!");
                } catch (e) {
                    console.error("Error guardando orden:", e);
                    alert("❌ Error: " + e.message);
                }
            }
        };

        

