																				</div>
																			</div>
                                ))
                            )}
                        
																		
																		</div>

                        {/* 3. FOOTER (RESUMEN SIMPLE) */}
                        {cart.length > 0 && (
                            
																		
																		<div className="p-5 bg-gray-50 dark:bg-luxury-card border-t border-gray-100 dark:border-gray-800 pb-safe shadow-[0_-5px_20px_rgba(0,0,0,0.05)]">
																			<div className="space-y-2 text-xs mb-4">
                                    {/* Subtotal */}
                                    
																				
																				<div className="flex justify-between text-gray-600 dark:text-gray-400">
																					<span>Subtotal</span>
																					<span>${originalTotal.toFixed(2)}</span>
																				</div>

                                    {/* Descuento Promo (Si aplica) */}
                                    {promoDiscount > 0 && (
                                        
																				
																				<div className="flex justify-between text-blue-600 dark:text-blue-400 font-bold">
																					<span>Descuento Promo</span>
																					<span>-${promoDiscount.toFixed(2)}</span>
																				</div>
                                    )}
                                    
                                    {/* Total (Sin Envío) */}
                                    
																				
																				<div className="flex justify-between items-end text-gray-900 dark:text-white pt-2 border-t border-gray-200 dark:border-gray-700 mt-2">
																					<span className="text-sm font-bold uppercase">Total</span>
                                        {/* Usamos cartTotal en vez de finalTotal para no sumar envío aun */}
                                        
																					
																					<span className="text-xl font-extrabold">${cartTotal.toFixed(2)}</span>
																				</div>
																				<p className="text-[9px] text-gray-400 text-right mt-1">* Envios calculados en el carrito.</p>
																			</div>
																			<button 
                                    onClick={()=>{
                                        setIsCartOpen(false); 
                                        setCheckoutStep(1); 
                                        setActiveTab('checkout'); 
                                    }} 
                                    className="w-full bg-black dark:bg-white text-white dark:text-black py-4 text-xs font-bold uppercase tracking-[0.2em] hover:opacity-90 transition-opacity shadow-xl"
                                >
                                    Comprar Ahora
                                </button>
																		</div>
                        )}
                    
																	
																	</div>
                  
                    
                    {isZoomOpen && selectedProduct && (
                        
																	
																	<ImageViewer 
                            images={selectedProduct.images || []}
                            currentIndex={currentImageIndex}
                            onIndexChange={setCurrentImageIndex}
                            onClose={() => setIsZoomOpen(false)} 
                        />
                    )}
                
																
																</div>
            );
        }
        

        const rootElement = document.getElementById('root');
        if (rootElement) {
            const root = createRoot(rootElement);
            root.render(
																
																<App />);
        }


															
															</script>
 </body>
</html>
