            const [status, setStatus] = useState("idle"); // idle, processing, sending, done

            // Función para procesar la imagen seleccionada
            const handleImageUpload = async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                setStatus("processing"); // Estado de carga
                try {
                    // Usamos la función resizeImage que ya tienes definida arriba
                    const base64 = await resizeImage(file);
                    setForm(prev => ({ ...prev, img: base64 }));
                    setStatus("idle");
                } catch (error) {
                    alert("Error procesando imagen: " + error);
                    setStatus("idle");
                }
            };

            const removeImage = () => setForm(prev => ({ ...prev, img: "" }));

            const send = async () => {
                if(!form.body.trim()) return alert("⚠️ Escribe un mensaje para enviar.");
                if(!confirm(`⚠️ ¿ESTÁS SEGURO?\n\nSe enviará este correo a TODOS los clientes registrados.\n\nTítulo: ${form.title}\n\nEsta acción no se puede deshacer.`)) return;
                
                setStatus("sending");
                try {
                    const { getDocs, collection } = window.FIREBASE_HELPERS;
                    // 1. Buscamos en AMBAS carpetas
                    const snapNuevos = await getDocs(collection(window.FIREBASE_DB, "clientes"));
                    const snapViejos = await getDocs(collection(window.FIREBASE_DB, "registros_clientes"));
                    
                    // 2. Unimos los resultados
                    const todosLosClientes = [...snapNuevos.docs, ...snapViejos.docs];
                    
                    if (todosLosClientes.length === 0) { alert("No hay clientes registrados."); setStatus("idle"); return; }
                    
                    let count = 0;
                    const correosProcesados = new Set(); // <-- Filtro de duplicados

                    for(const doc of todosLosClientes) {
                        const c = doc.data();
                        const email = c.email ? c.email.toLowerCase().trim() : "";
                        
                        if(email.includes("@") && !correosProcesados.has(email)) {
                             correosProcesados.add(email);
                             await emailjs.send(EMAIL_CONFIG.SERVICE_ID, EMAIL_CONFIG.TEMPLATE_ID, {
                                to_name: c.nombre || "Cliente", 
                                to_email: email,
                                message: form.body, 
                                subject_override: form.title, 
                                my_image: form.img,
                                member_id: c.member_id || "NOVA"
                             }).catch(e => console.log("Error individual:", e));
                             
                             count++;
                             await new Promise(r=>setTimeout(r, 400)); 
                        }
                    }
                    alert(`✅ ¡Campaña Finalizada!\n\nSe enviaron correos a ${count} clientes (sin duplicados).`);
                    setStatus("done");
                    onClose();
                } catch(e) { 
                    console.error(e); 
                    alert("❌ Error de conexión: "+e.message); 
                    setStatus("idle"); 
