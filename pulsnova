																					<button onClick={handleCrop} className="text-black font-bold text-xs bg-luxury-gold px-4 py-2 rounded-full">✓ Usar Foto</button>
																				</div>
																				<div className="flex-1 relative bg-[#111] flex items-center justify-center overflow-hidden">
																					<img ref={imageRef} src={imageSrc} style={{ maxWidth: '100%', maxHeight: '80vh' }} />
																				</div>
																				<div className="p-4 bg-black text-center border-t border-gray-800 pb-safe">
																					<p className="text-gray-500 text-[10px] uppercase tracking-wide">Pellizca para zoom • Arrastra para encuadrar</p>
																				</div>
																			</div>
            );

            return (
                
				
				
																			
																			<div className="fixed inset-0 z-[80] bg-black flex flex-col animate-fade-in">
																				<div className="flex justify-between items-center p-4 bg-black z-10 border-b border-gray-800">
