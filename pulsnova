																					<button onClick={handleCrop} className="text-black font-bold text-xs bg-luxury-gold px-4 py-2 rounded-full">✓ Guardar</button>
																				</div>
																				<div className="flex-1 relative bg-[#111] flex items-center justify-center overflow-hidden">
																					<img ref={imageRef} src={imageSrc} style={{ maxWidth: '100%', maxHeight: '80vh' }} />
																				</div>
																				<div className="p-4 bg-black text-center border-t border-gray-800 pb-safe">
																					<p className="text-gray-500 text-[10px] uppercase tracking-wide">Arrastra para mover • Pellizca para zoom</p>
																				</div>
																			</div>
            );
